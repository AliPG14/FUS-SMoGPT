<Window x:Class="FUS_SMoGPT.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FUS-SMoGPT | Quản Lý Sinh Viên"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="16" Background="{StaticResource BgDarkBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.3" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>   <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="36"/>   <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- ===== HEADER BAR ===== -->
            <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" CornerRadius="16,16,0,0">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🎓" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="FUS-SMoGPT" FontSize="20" FontWeight="Bold" 
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Welcome Message -->
                    <TextBlock Grid.Column="1" 
                               Text="{Binding WelcomeMessage}" 
                               Foreground="#CCFFFFFF"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                        <!-- Logout Button -->
                        <Button Content="🚪 Đăng xuất" 
                                Command="{Binding LogoutCommand}"
                                Margin="0,0,8,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#33FFFFFF" CornerRadius="8" Padding="14,8">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#55FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>

                        <!-- Window Controls -->
                        <Button Content="—" Foreground="White" Width="36" Height="36"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="MinimizeButton_Click" FontSize="14">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="☐" Foreground="White" Width="36" Height="36"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="MaximizeButton_Click" FontSize="14">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✕" Foreground="White" Width="36" Height="36"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="CloseButton_Click" FontSize="14">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#AAFF4444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Grid.Row="1" Margin="20,16,20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Student List -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                            <RowDefinition Height="*"/>     <!-- DataGrid -->
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search Box (Admin only) -->
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="🔍 Tìm kiếm sinh viên..."
                                     Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,0,12,0"/>

                            <!-- CRUD Buttons (Admin only) -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="➕ Thêm" 
                                        Style="{StaticResource SuccessButton}"
                                        Command="{Binding AddStudentCommand}"
                                        Padding="16,10" FontSize="13" Margin="0,0,6,0"/>
                                <Button Content="✏️ Sửa" 
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding EditStudentCommand}"
                                        Padding="16,10" FontSize="13" Margin="0,0,6,0"/>
                                <Button Content="🗑️ Xóa" 
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding DeleteStudentCommand}"
                                        Padding="16,10" FontSize="13" Margin="0,0,6,0"/>
                                <Button Content="🔄" 
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding RefreshCommand}"
                                        Padding="10,10" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="1"
                                  Style="{StaticResource ModernDataGrid}"
                                  ItemsSource="{Binding Students}"
                                  SelectedItem="{Binding SelectedStudent}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  CellStyle="{StaticResource ModernDataGridCell}"
                                  RowStyle="{StaticResource ModernDataGridRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="MSSV" Binding="{Binding Mssv}" Width="100"/>
                                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Ngành Học" Binding="{Binding NganhHoc}" Width="160"/>
                                <DataGridTextColumn Header="Khóa" Binding="{Binding KhoaHoc}" Width="65"/>
                                <DataGridTextColumn Header="GPA" Binding="{Binding Gpa, StringFormat=F2}" Width="60"/>
                                <DataGridTextColumn Header="Học Lực" Binding="{Binding HocLucDisplay}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- RIGHT: Student Detail Panel -->
                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Panel Title -->
                            <TextBlock Text="📋 Chi Tiết Sinh Viên" 
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,20"/>

                            <!-- No Selection -->
                            <StackPanel x:Name="NoSelectionPanel" Visibility="Visible">
                                <TextBlock Text="👆" FontSize="40" HorizontalAlignment="Center" Margin="0,40,0,12"/>
                                <TextBlock Text="Chọn một sinh viên&#10;để xem chi tiết"
                                           FontSize="14" 
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           LineHeight="24"/>
                            </StackPanel>

                            <!-- Student Details (shown when selected) -->
                            <StackPanel x:Name="DetailPanel" Visibility="Collapsed">

                                <!-- Avatar Circle -->
                                <Border Width="72" Height="72" CornerRadius="36"
                                        Background="{StaticResource PrimaryGradient}"
                                        HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <TextBlock x:Name="AvatarText" Text="?" 
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name -->
                                <TextBlock x:Name="DetailName" Text="" 
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,0,0,4"/>

                                <TextBlock x:Name="DetailMssv" Text=""
                                           FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,20"/>

                                <!-- Separator -->
                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                                <!-- Detail Fields -->
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="NGÀNH HỌC" Style="{StaticResource LabelText}"/>
                                    <TextBlock x:Name="DetailNganh" Text="" FontSize="14" 
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                                    <TextBlock Text="KHÓA HỌC" Style="{StaticResource LabelText}"/>
                                    <TextBlock x:Name="DetailKhoa" Text="" FontSize="14"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                                    <TextBlock Text="ĐIỂM GPA" Style="{StaticResource LabelText}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <TextBlock x:Name="DetailGpa" Text="" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource SecondaryBrush}"/>
                                        <TextBlock Text=" / 4.0" FontSize="16" 
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                    </StackPanel>

                                    <TextBlock Text="HỌC LỰC" Style="{StaticResource LabelText}"/>
                                    <Border x:Name="HocLucBadge" CornerRadius="8" Padding="12,8" 
                                            HorizontalAlignment="Left" Margin="0,0,0,4">
                                        <TextBlock x:Name="DetailHocLuc" Text="" 
                                                   FontSize="14" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ===== STATUS BAR ===== -->
            <Border Grid.Row="2" Background="{StaticResource BgCardBrush}"
                    CornerRadius="0,0,16,16"
                    Padding="20,0">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="FUS-SMoGPT v1.0 | WPF .NET"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
