<Window x:Class="FUS_SMoGPT.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FUS-SMoGPT | Đăng Nhập"
        Width="480" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Main Container with rounded corners -->
    <Border CornerRadius="20" Background="{StaticResource BgDarkBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" Color="#FF4E54C8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Close Button -->
            <Button Grid.Row="0" Content="✕" 
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,12,16,0" Width="32" Height="32"
                    FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Click="CloseButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="8" 
                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#44FF4444"/>
                                <Setter Property="Foreground" Value="#FFFF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Login Form Content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="48,0,48,30">

                <!-- Logo / Branding -->
                <TextBlock Text="🎓" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock Text="FUS-SMoGPT" 
                           FontSize="32" FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF4E54C8" Offset="0"/>
                            <GradientStop Color="#FF00D2FF" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="Student Management System" 
                           Style="{StaticResource SubtitleText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,36"/>

                <!-- Username -->
                <TextBlock Text="TÊN ĐĂNG NHẬP" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="UsernameTextBox"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,18"
                         KeyDown="TextBox_KeyDown"/>

                <!-- Password -->
                <TextBlock Text="MẬT KHẨU" Style="{StaticResource LabelText}"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,8"
                             KeyDown="PasswordBox_KeyDown"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorText"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,4,0,16"
                           Visibility="{Binding IsErrorVisible, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Login Button -->
                <Button Content="🔐  ĐĂNG NHẬP"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        FontSize="15"
                        Padding="24,16"
                        Margin="0,8,0,20"/>

                <!-- Help Text -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="14,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💡 Hướng dẫn đăng nhập:" 
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="• Admin: username = admin | mật khẩu = 123"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="• Sinh viên: username = MSSV | mật khẩu = 1"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Border>
</Window>
